WELCOMEEOF

# Show the welcome message
clear
cat /tmp/acreetionos-welcome.txt
read -r

# Mark as done
sudo mkdir -p "$(dirname "${MARKER}")" 2>/dev/null || true
sudo touch "${MARKER}" 2>/dev/null || true

# Clean up
rm -f /tmp/acreetionos-welcome.txt
