#!/usr/bin/env bash
# ==============================================================================
# AcreetionOS Server — Toolbox
# Every server maintainer's dream toolkit, categorized and launchable.
# Browse, learn, and launch tools from one place.
# ==============================================================================
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; MAG='\033[0;35m'; NC='\033[0m'

BOLD='\033[1m'

log()   { echo -e "${GREEN}[✓]${NC} $1"; }
info()  { echo -e "${BLUE}[i]${NC} $1"; }
warn()  { echo -e "${YELLOW}[!]${NC} $1"; }
title() { echo -e "\n${CYAN}${BOLD}━━━ $1 ━━━${NC}\n"; }

# ── Tool Database ──────────────────────────────────────────────────────────
# Each entry: category | name | description | command to launch
TOOLS=(
    # ── SYSTEMD ADMINISTRATION ──
    "Systemd|acreetionos-systemd|Complete systemd admin (services, timers, journals, boot, targets, sockets, more)|sudo acreetionos-systemd"
    
    # ── SETUP WIZARDS ──
    "Wizards|acreetionos-wizard|Master setup hub — all wizards in one place|sudo acreetionos-wizard"
    "Wizards|Setup Wizard|Full system setup — hostname, locale, timezone, users|sudo acreetionos-wizard-setup"
    "Wizards|Firewall|Configure ports, presets, custom rules|sudo acreetionos-wizard-firewall"
    "Wizards|Databases|Initialize MariaDB/PostgreSQL, create databases|sudo acreetionos-wizard-database"
    "Wizards|Security|SSH keys, fail2ban, audit, rootkits, AV|sudo acreetionos-wizard-security"
    "Wizards|Backup|Configure restic/borg/timeshift, enable schedule|sudo acreetionos-wizard-backup"
    "Wizards|Monitoring|Prometheus, Grafana, Netdata setup|sudo acreetionos-wizard-monitoring"
    "Wizards|Docker Stacks|Deploy LEMP, WordPress, Nextcloud, more|sudo acreetionos-wizard-stacks"
    "Wizards|Network|Static IP, bridges, VLANs, DNS|sudo acreetionos-wizard-network"
    "Wizards|Virtual Machine|Create and manage VMs|sudo acreetionos-wizard-vm"
    "Systemd|List services|Show all running services|systemctl list-units --type=service --state=running --no-pager --no-legend | head -40"
    "Systemd|List timers|Show scheduled timers|systemctl list-timers --all --no-pager | head -30"
    "Systemd|Journal follow|Watch live system logs|journalctl -f --no-hostname -o short-iso"
    "Systemd|Boot analysis|Analyze boot performance|systemd-analyze && systemd-analyze blame | head -20"
    "Systemd|Failed units|Show and troubleshoot failed services|systemctl --failed --no-pager"
    "Systemd|Resource usage|Per-service CPU/memory via cgroups|systemd-cgtop"
    "Systemd|Boot plot|Generate SVG boot performance chart|systemd-analyze plot > /tmp/boot-plot.svg && echo 'Saved to /tmp/boot-plot.svg'"
    "Systemd|Systemd-delta|Show unit file overrides|systemd-delta --no-pager"
    
    # ── WEB-BASED SERVER MANAGEMENT ──
    "Web Admin|acreetionos-systemd|Complete systemd admin — services, timers, journals, boot analysis, more|sudo acreetionos-systemd"
    "Web Admin|Cockpit|Web-based server management console|systemctl start cockpit.socket 2>/dev/null; xdg-open https://localhost:9090 2>/dev/null || echo 'Open https://localhost:9090 in a browser'"
    "Web Admin|Cockpit Machines|Virtual machine management via Cockpit|cockpit-machines"
    "Web Admin|Cockpit Podman|Container management via Cockpit|cockpit-podman"
    "Web Admin|Cockpit Storage|Storage management via Cockpit|cockpit-storaged"
    
    # ── SYSTEM MONITORING ──
    "Monitoring|htop|Interactive process viewer|htop"
    "Monitoring|btop|Modern resource monitor with themes|btop"
    "Monitoring|btm/bottom|Graphical system monitor|btm"
    "Monitoring|glances|Python system monitor — web + terminal|glances"
    "Monitoring|atop|Advanced system & process monitor|atop"
    "Monitoring|procs|Modern ps replacement|procs"
    "Monitoring|bpytop|Resource monitor (Python)|bpytop"
    "Monitoring|nvtop|GPU monitoring|nvtop"
    "Monitoring|iotop|I/O monitoring (needs root)|sudo iotop"
    "Monitoring|netdata|Real-time monitoring dashboard|systemctl start netdata 2>/dev/null; echo 'Open http://localhost:19999'"
    
    # ── DISK & STORAGE ──
    "Storage|ncdu|Interactive disk usage analyzer|ncdu /"
    "Storage|gdu|Fast disk usage analyzer (Go)|gdu /"
    "Storage|duf|Modern df replacement|duf"
    "Storage|dust|More intuitive du|dust"
    "Storage|dua-cli|Disk usage analyzer|dua /"
    "Storage|testdisk|Partition recovery & undelete|sudo testdisk"
    "Storage|ddrescue|Data recovery tool|sudo ddrescue"
    "Storage|fsarchiver|Filesystem backup/restore|sudo fsarchiver"
    "Storage|timeshift|System snapshot tool|sudo timeshift --list"
    "Storage|smartctl|SMART disk health check|sudo smartctl -a /dev/sda"
    
    # ── NETWORK TOOLS ──
    "Network|nmap|Port scanner & network explorer|nmap"
    "Network|tcpdump|Packet analyzer|sudo tcpdump"
    "Network|wireshark-cli|CLI packet analyzer (tshark)|sudo tshark"
    "Network|ngrep|Network grep — packet inspection|sudo ngrep"
    "Network|iperf3|Network throughput tester|iperf3"
    "Network|nethogs|Per-process network usage|sudo nethogs"
    "Network|bmon|Bandwidth monitor|bmon"
    "Network|vnstat|Network traffic logger|vnstat --help"
    "Network|jnettop|Traffic visualization|jnettop"
    "Network|mtr|Traceroute + ping combined|mtr 8.8.8.8"
    "Network|bandwhich|Terminal bandwidth utilization|bandwhich"
    "Network|dog|Modern DNS client|dog"
    "Network|arp-scan|ARP scanner|sudo arp-scan --local"
    "Network|socat|Networking Swiss Army knife|socat -h"
    "Network|netcat|TCP/IP Swiss Army knife|nc -h"
    
    # ── TERMINAL FILE MANAGERS ──
    "Files|mc|Midnight Commander (two-panel file manager)|mc"
    "Files|ranger|VI-keyed file manager|ranger"
    "Files|lf|Terminal file manager (Go)|lf"
    "Files|nnn|Tiny file manager|nnn"
    
    # ── MODERN CLI REPLACEMENTS ──
    "Modern|bat|cat with syntax highlighting|bat"
    "Modern|ripgrep (rg)|Blazingly fast grep|rg"
    "Modern|fd|Fast find replacement|fd"
    "Modern|jq|JSON processor|jq"
    "Modern|yq|YAML/JSON/XML processor|yq"
    "Modern|delta|Better git diff viewer|delta"
    "Modern|sd|Find & replace CLI|sd"
    "Modern|fzf|Fuzzy finder (pipe to it)|fzf"
    "Modern|zoxide|Smarter cd (learns your paths)|zoxide"
    "Modern|cheat|Command cheatsheets|cheat"
    "Modern|tldr|Simplified man pages|tldr"
    "Modern|tealdeer|Fast tldr client|tldr"
    "Modern|micro|Modern terminal editor|micro"
    "Modern|choose|Human-friendly cut|choose"
    "Modern|hexyl|Hex viewer|hexyl"
    "Modern|hyperfine|Benchmark any command|hyperfine"
    
    # ── LOG MANAGEMENT ──
    "Logs|lnav|Log file navigator (multiple files)|lnav"
    "Logs|journalctl|Systemd journal viewer|journalctl -xe"
    
    # ── CONTAINER MANAGEMENT ──
    "Containers|lazydocker|Terminal UI for Docker|lazydocker"
    "Containers|ctop|Container monitoring|ctop"
    "Containers|docker|Container runtime|docker ps"
    "Containers|docker-compose|Multi-container orchestration|docker-compose"
    
    # ── DATABASE TOOLS ──
    "Database|mycli|MySQL CLI with auto-completion|mycli"
    "Database|pgcli|PostgreSQL CLI with auto-completion|pgcli"
    "Database|usql|Universal SQL client|usql"
    "Database|mariadb|MariaDB server|mariadb --help"
    "Database|postgresql|PostgreSQL server|psql --help"
    "Database|redis|Redis server|redis-cli --help"
    
    # ── SECURITY & HARDENING ──
    "Security|lynis|Security auditing|lynis audit system"
    "Security|rkhunter|Rootkit hunter|sudo rkhunter --check"
    "Security|chkrootkit|Rootkit checker|sudo chkrootkit"
    "Security|fail2ban|Intrusion prevention|fail2ban-client status"
    "Security|clamav|Antivirus scanner|clamscan --help"
    "Security|nftables|Firewall manager|sudo nft list ruleset"
    
    # ── DEVELOPMENT ──
    "Dev|git|Version control|git"
    "Dev|gh|GitHub CLI|gh"
    "Dev|glab|GitLab CLI|glab"
    "Dev|httpie|HTTP client (human-friendly)|httpie"
    "Dev|curlie|curl with httpie syntax|curlie"
    "Dev|make|Build system|make"
    "Dev|cmake|Build system|cmake"
    
    # ── REMOTE ACCESS ──
    "Remote|ssh|Secure shell|ssh"
    "Remote|mosh|Mobile shell (roaming SSH)|mosh"
    "Remote|byobu|Tmux/Screen wrapper|byobu"
    "Remote|tmux|Terminal multiplexer|tmux"
    "Remote|screen|Terminal multiplexer|screen"
    
    # ── BACKUP ──
    "Backup|restic|Deduplicating backup|restic --help"
    "Backup|borg|Deduplicating backup|borg --help"
    "Backup|timeshift|System snapshots|sudo timeshift --help"
    
    # ── MISC ──
    "Misc|asciinema|Terminal recording|asciinema"
    "Misc|entr|Run command on file change|entr"
    "Misc|parallel|Run commands in parallel|parallel"
    "Misc|rlwrap|Readline wrapper|rlwrap"
    "Misc|units|Unit converter|units"
    "Misc|pv|Pipe viewer (progress)|pv"
    "Misc|zstd|Fast compression|zstd"
)

# ── Categories ──
CATEGORIES=()
for tool in "${TOOLS[@]}"; do
    cat="${tool%%|*}"
    seen=false
    for c in "${CATEGORIES[@]}"; do [[ "$c" == "$cat" ]] && seen=true; done
    $seen || CATEGORIES+=("$cat")
done

show_banner() {
    clear
    CURRENT_USER=$(whoami)
    echo -e "${CYAN}"
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║         AcreetionOS Server — Toolbox                        ║"
    echo "║  Every server maintainer's dream toolkit                    ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
    echo -e "  ${BOLD}Logged in as:${NC} ${GREEN}${CURRENT_USER}${NC}"
    echo -e "  ${BOLD}Your groups:${NC}  ${YELLOW}$(groups ${CURRENT_USER} 2>/dev/null | sed 's/.*: //')${NC}"
    echo ""
    echo -e "  ${BLUE}User recommendations:${NC}"
    echo -e "    admin    → Full system administration"
    echo -e "    dbadmin  → Database operations (postgres, mysql)"
    echo -e "    webadmin → Web server management (nginx, apache, certbot)"
    echo -e "    ops      → Containers, monitoring, operations"
    echo -e "    backup   → Backup & recovery"
    echo -e "    root     → Everything (use sparingly)"
    echo ""
}

show_category_menu() {
    show_banner
    echo -e "${BOLD}Categories:${NC}\n"
    local i=0
    for cat in "${CATEGORIES[@]}"; do
        i=$((i+1))
        count=0
        for tool in "${TOOLS[@]}"; do
            [[ "${tool%%|*}" == "$cat" ]] && count=$((count+1))
        done
        printf "  ${CYAN}%2d)${NC} %-20s ${GREEN}[%2d tools]${NC}\n" "$i" "$cat" "$count"
    done
    echo ""
    echo "  ${YELLOW} a)${NC} About this toolbox"
    echo "  ${YELLOW} s)${NC} Search all tools"
    echo "  ${YELLOW} q)${NC} Quit"
    echo ""
    read -r -p "  Choice: " choice
}

show_tools_in_category() {
    local selected_cat="$1"
    local tools_in_cat=()
    local i=0
    
    for tool in "${TOOLS[@]}"; do
        cat="${tool%%|*}"
        if [[ "$cat" == "$selected_cat" ]]; then
            tools_in_cat+=("$tool")
        fi
    done
    
    while true; do
        clear
        echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${CYAN}║${NC}  ${BOLD}${selected_cat}${NC} — ${#tools_in_cat[@]} tools"
        echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        
        local i=0
        for tool in "${tools_in_cat[@]}"; do
            IFS='|' read -r _ name desc _ <<< "$tool"
            i=$((i+1))
            printf "  ${CYAN}%2d)${NC} ${BOLD}%-20s${NC} %s\n" "$i" "$name" "$desc"
        done
        
        echo ""
        echo "  ${YELLOW} <enter>)${NC} Launch a tool by number"
        echo "  ${YELLOW} b)${NC} Back to categories"
        echo "  ${YELLOW} q)${NC} Quit"
        echo ""
        read -r -p "  Choice: " choice
        
        case "$choice" in
            q|Q) exit 0 ;;
            b|B) return ;;
            ''|*)
                if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#tools_in_cat[@]}" ]; then
                    idx=$((choice-1))
                    IFS='|' read -r _ name _ cmd <<< "${tools_in_cat[$idx]}"
                    echo ""
                    echo -e "${GREEN}Launching: ${BOLD}$name${NC}"
                    echo -e "${BLUE}Command:${NC} $cmd"
                    echo ""
                    read -r -p "Press Enter to launch (or Ctrl+C to cancel)..."
                    echo ""
                    eval "$cmd"
                    echo ""
                    read -r -p "Press Enter to continue..."
                fi
                ;;
        esac
    done
}

search_tools() {
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}  ${BOLD}Search Tools${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    read -r -p "  Search term: " query
    echo ""
    
    results=()
    for tool in "${TOOLS[@]}"; do
        if echo "$tool" | grep -qi "$query"; then
            results+=("$tool")
        fi
    done
    
    if [ ${#results[@]} -eq 0 ]; then
        warn "No tools match '$query'"
        read -r -p "Press Enter..."
        return
    fi
    
    echo -e "${GREEN}${#results[@]} tool(s) matching '${query}':${NC}\n"
    local i=0
    for tool in "${results[@]}"; do
        IFS='|' read -r cat name desc _ <<< "$tool"
        i=$((i+1))
        printf "  ${CYAN}%2d)${NC} ${BOLD}%-20s${NC} ${YELLOW}[%s]${NC} — %s\n" "$i" "$name" "$cat" "$desc"
    done
    echo ""
    read -r -p "Launch a tool by number, or Enter to go back: " choice
    if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#results[@]}" ]; then
        idx=$((choice-1))
        IFS='|' read -r _ name _ cmd <<< "${results[$idx]}"
        echo ""
        echo -e "${GREEN}Launching: ${BOLD}$name${NC}"
        eval "$cmd"
        echo ""
        read -r -p "Press Enter..."
    fi
}

show_about() {
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}  ${BOLD}About the AcreetionOS Toolbox${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  This toolbox contains ${#TOOLS[@]} tools across ${#CATEGORIES[@]} categories."
    echo "  Every tool is pre-installed and ready to use."
    echo ""
    echo "  ${BOLD}Categories:${NC}"
    for cat in "${CATEGORIES[@]}"; do
        count=0
        for tool in "${TOOLS[@]}"; do
            [[ "${tool%%|*}" == "$cat" ]] && count=$((count+1))
        done
        printf "    ${CYAN}●${NC} %-20s ${GREEN}(%d tools)${NC}\n" "$cat" "$count"
    done
    echo ""
    echo "  ${BOLD}Quick start:${NC}"
    echo "    sudo acreetionos-maintain   — System maintenance menu"
    echo "    sudo acreetionos-toolbox     — This toolbox launcher"
    echo "    sudo acreetionos-strip-gui   — Remove desktop, go TTY"
    echo "    sudo acreetionos-install-gui — Reinstall desktop"
    echo ""
    echo "  ${BOLD}#KeepLinuxFree${NC} ${BOLD}#AcreetionOSWillAlwaysBeFree${NC}"
    echo ""
    read -r -p "Press Enter..."
}

# ── Main Loop ──
while true; do
    show_category_menu
    case "$choice" in
        q|Q) echo ""; log "Happy server maintaining!"; exit 0 ;;
        a|A) show_about ;;
        s|S) search_tools ;;
        ''|*)
            if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "${#CATEGORIES[@]}" ]; then
                idx=$((choice-1))
                show_tools_in_category "${CATEGORIES[$idx]}"
            fi
            ;;
    esac
done
