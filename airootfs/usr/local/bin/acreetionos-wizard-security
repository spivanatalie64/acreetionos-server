#!/usr/bin/env bash
# AcreetionOS Server — Security Setup Wizard
# SSH keys, fail2ban, system audit, permission hardening.
set -euo pipefail
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'; BOLD='\033[1m'
[[ $EUID -ne 0 ]] && exec sudo "$0" "$@"

while true; do
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}           ${BOLD}Security Configuration${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  1)  Set up SSH key authentication"
    echo "  2)  Run system security audit (lynis)"
    echo "  3)  Configure fail2ban"
    echo "  4)  Run rootkit scanner"
    echo "  5)  Run antivirus scan (clamav)"
    echo "  6)  Check for world-writable files"
    echo "  7)  Check for SUID root binaries"
    echo "  8)  View last failed login attempts"
    echo "  9)  View active SSH sessions"
    echo " 10)  Enable automatic security updates"
    echo ""
    echo "  b)  Back"
    echo ""
    read -r -p "  Choice: " sc
    case "$sc" in
        1)
            echo ""; read -r -p "  Username to add key for (admin/ops): " skuser
            id "$skuser" &>/dev/null || { echo "  User not found"; continue; }
            mkdir -p "/home/$skuser/.ssh"
            echo "  Paste the public key, then press Ctrl+D (or type it and Enter):"
            read -r pubkey
            [[ -z "$pubkey" ]] && continue
            echo "$pubkey" >> "/home/$skuser/.ssh/authorized_keys"
            chmod 700 "/home/$skuser/.ssh"
            chmod 600 "/home/$skuser/.ssh/authorized_keys"
            chown -R "$skuser:$skuser" "/home/$skuser/.ssh"
            echo -e "${GREEN}[✓]${NC} SSH key added for $skuser" ;;
        2)
            if command -v lynis &>/dev/null; then
                echo "  Running lynis audit (this may take a minute)..."
                lynis audit system 2>/dev/null | tail -40 || true
            else
                echo "  lynis not installed."
            fi ;;
        3)
            if ! command -v fail2ban-client &>/dev/null; then
                echo "  fail2ban not installed. Install with: pacman -S fail2ban"
                continue
            fi
            mkdir -p /etc/fail2ban
            cat > /etc/fail2ban/jail.local << 'JAIL'
[DEFAULT]
bantime = 1h
findtime = 10m
maxretry = 5

[sshd]
enabled = true
port = ssh
filter = sshd
logpath = /var/log/auth.log
maxretry = 3
JAIL
            systemctl enable --now fail2ban.service 2>/dev/null || true
            echo -e "${GREEN}[✓]${NC} fail2ban configured for SSH (3 retries → 1h ban)" ;;
        4)
            if command -v rkhunter &>/dev/null; then
                rkhunter --check --skip-keypress 2>/dev/null | tail -30 || true
            else
                echo "  rkhunter not installed." ;;
            fi ;;
        5)
            if command -v clamscan &>/dev/null; then
                echo "  Updating virus definitions..."
                freshclam 2>/dev/null || true
                echo "  Scanning /home and /etc..."
                clamscan -r /home /etc --quiet 2>/dev/null || true
                echo -e "${GREEN}[✓]${NC} Scan complete."
            else
                echo "  clamav not installed." ;;
            fi ;;
        6)
            echo "  Checking for world-writable files..."
            find /etc -type f -perm -o+w -ls 2>/dev/null | head -20
            find /home -type f -perm -o+w -ls 2>/dev/null | head -20
            echo "  (only first 20 shown)" ;;
        7)
            echo "  SUID root binaries:"
            find /usr/bin /usr/sbin -perm -4000 -type f 2>/dev/null | sed 's/^/  /' ;;
        8)
            echo "  Last failed logins:"
            lastb 2>/dev/null | head -20 || journalctl -u sshd -n 20 --no-pager --no-hostname 2>/dev/null | grep -i "failed\|invalid" | tail -20 || echo "  (no failed login data)" ;;
        9)
            echo "  Active SSH sessions:"
            who 2>/dev/null | grep -i pts || ss -tnp 2>/dev/null | grep :22 || echo "  (no active sessions)" ;;
        10)
            systemctl enable acreetionos-auto-update.timer 2>/dev/null || true
            systemctl start acreetionos-auto-update.timer 2>/dev/null || true
            echo -e "${GREEN}[✓]${NC} Automatic security updates enabled (weekly)" ;;
        b|B) return ;;
    esac
    echo ""; read -r -p "Press Enter..."
done
