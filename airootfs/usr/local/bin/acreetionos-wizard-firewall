#!/usr/bin/env bash
# AcreetionOS Server — Firewall Wizard
# Interactive nftables rule management with presets.
set -euo pipefail
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'
[[ $EUID -ne 0 ]] && exec sudo "$0" "$@"

CONFIG="/etc/nftables/acreetionos-server.conf"
RULES=$(nft list ruleset 2>/dev/null || echo "")

list_open_ports() {
    echo "$RULES" | grep "tcp dport" | sed 's/.*tcp dport //' | sed 's/ accept//' | tr ',' '\n' | sed 's/^[[:space:]]*//' | sed 's/{//g; s/}//g'
}

while true; do
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}           ${BOLD}Firewall Configuration${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  ${BOLD}Current open ports:${NC}"
    current=$(list_open_ports)
    if [[ -z "$current" ]]; then
        echo "    (none — only SSH is open)"
    else
        echo "$current" | sed 's/^/    /'
    fi
    echo ""
    echo "  1)  Apply SSH-only (default deny)"
    echo "  2)  Open HTTP/HTTPS (80, 443)"
    echo "  3)  Open a custom port"
    echo "  4)  Close a specific port"
    echo "  5)  Preset: Web server (22, 80, 443)"
    echo "  6)  Preset: Database server (22, 3306, 5432)"
    echo "  7)  Preset: Monitoring (22, 9090, 3000, 19999)"
    echo "  8)  Preset: Mail server (22, 25, 587, 465, 993)"
    echo "  9)  Wide open (all ports — not recommended)"
    echo " 10)  View current rules"
    echo " 11)  Disable firewall (allow all)"
    echo ""
    echo "  b)  Back"
    echo ""
    read -r -p "  Choice: " fc

    flush_and_apply() {
        local ports="$1"
        nft flush ruleset 2>/dev/null || true
        cat > "$CONFIG" << 'NFTEOF'
#!/usr/sbin/nft -f
table inet acreetionos {
    chain input {
        type filter hook input priority 0; policy drop;
        ct state { established, related } accept
        iif lo accept
        icmp type { echo-request } accept
NFTEOF
        for port in $ports; do
            echo "        tcp dport $port accept" >> "$CONFIG"
        done
        cat >> "$CONFIG" << 'NFTEOF2'
    }
    chain forward {
        type filter hook forward priority 0; policy drop;
    }
    chain output {
        type filter hook output priority 0; policy accept;
    }
}
NFTEOF2
        nft -f "$CONFIG" 2>/dev/null || true
        echo -e "${GREEN}[✓]${NC} Firewall applied — open ports: $ports"
    }

    case "$fc" in
        1) flush_and_apply "22" ;;
        2) flush_and_apply "22 80 443" ;;
        3)
            read -r -p "  Port number: " cport
            [[ -z "$cport" ]] && continue
            new_ports=$(list_open_ports; echo "$cport")
            flush_and_apply "$(echo "$new_ports" | tr '\n' ' ')" ;;
        4)
            read -r -p "  Port to close: " dport
            [[ -z "$dport" ]] && continue
            remaining=$(list_open_ports | grep -v "^$dport$" | tr '\n' ' ')
            flush_and_apply "$remaining" ;;
        5) flush_and_apply "22 80 443" ;;
        6) flush_and_apply "22 3306 5432" ;;
        7) flush_and_apply "22 9090 3000 19999" ;;
        8) flush_and_apply "22 25 587 465 993" ;;
        9)
            nft flush ruleset 2>/dev/null || true
            echo '#!/usr/sbin/nft -f' > "$CONFIG"
            echo 'table inet acreetionos { chain input { type filter hook input priority 0; policy accept; } chain forward { type filter hook forward priority 0; policy accept; } chain output { type filter hook output priority 0; policy accept; } }' >> "$CONFIG"
            echo -e "${YELLOW}[!]${NC} Firewall disabled — all traffic allowed" ;;
        10) echo "" && nft list ruleset 2>/dev/null || echo "  (no rules)" ;;
        11)
            nft flush ruleset 2>/dev/null || true
            systemctl stop nftables.service 2>/dev/null || true
            echo -e "${YELLOW}[!]${NC} nftables stopped and disabled"
            echo "  WARNING: Your server is now unprotected." ;;
        b|B) return ;;
    esac
    echo ""; read -r -p "Press Enter..."
done
