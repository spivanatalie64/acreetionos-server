#!/usr/bin/env bash
# ==============================================================================
# AcreetionOS Server — Master Setup Wizard
# Hub for every server setup task. Firewall, databases, security, backup,
# monitoring, docker stacks, network, VMs, and system configuration.
# ==============================================================================
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'

[[ $EUID -ne 0 ]] && exec sudo "$0" "$@"

while true; do
    clear
    echo -e "${CYAN}"
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║     AcreetionOS Server — Setup Wizard                       ║"
    echo "║  Configure your server the way you want it                  ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
    echo "  1)  🔥 Firewall        — Configure ports & rules"
    echo "  2)  🗄️  Databases       — Initialize MariaDB / PostgreSQL"
    echo "  3)  🔒 Security        — SSH keys, fail2ban, audit"
    echo "  4)  💾 Backup          — Set up automatic backups"
    echo "  5)  📊 Monitoring      — Prometheus, Grafana, Netdata"
    echo "  6)  🐳 Docker Stacks   — Deploy nginx+php+mysql, monitoring stack"
    echo "  7)  🌐 Network         — Static IP, bridges, VLANs"
    echo "  8)  🖥️  Virtual Machine — Create a VM via libvirt"
    echo "  9)  ⚙️  System Setup   — Hostname, locale, timezone, users"
    echo ""
    echo "  q)  Quit"
    echo ""
    read -r -p "  Choice: " choice
    case "$choice" in
        1)  acreetionos-wizard-firewall; read -r -p "Press Enter..." ;;
        2)  acreetionos-wizard-database; read -r -p "Press Enter..." ;;
        3)  acreetionos-wizard-security; read -r -p "Press Enter..." ;;
        4)  acreetionos-wizard-backup; read -r -p "Press Enter..." ;;
        5)  acreetionos-wizard-monitoring; read -r -p "Press Enter..." ;;
        6)  acreetionos-wizard-stacks; read -r -p "Press Enter..." ;;
        7)  acreetionos-wizard-network; read -r -p "Press Enter..." ;;
        8)  acreetionos-wizard-vm; read -r -p "Press Enter..." ;;
        9)  acreetionos-wizard-setup; read -r -p "Press Enter..." ;;
        q|Q) echo ""; log "Happy server maintaining!"; exit 0 ;;
    esac
done
