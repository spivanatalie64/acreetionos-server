#!/usr/bin/env bash
# ==============================================================================
# AcreetionOS Server — System Maintenance Tool
# One-stop shop for keeping your server healthy.
# Arch-based, just better, more stable.
# ==============================================================================
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'

log()  { echo -e "${GREEN}[✓]${NC} $1"; }
info() { echo -e "${BLUE}[i]${NC} $1"; }
warn() { echo -e "${YELLOW}[!]${NC} $1"; }
err()  { echo -e "${RED}[✗]${NC} $1"; }

if [[ $EUID -ne 0 ]]; then
    exec sudo "$0" "$@"
fi

show_menu() {
    clear
    echo -e "${CYAN}"
    echo "╔══════════════════════════════════════════════════════════════╗"
    echo "║           AcreetionOS Server — Maintenance                  ║"
    echo "╚══════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
    echo "  1)  Update system (pacman -Syu)"
    echo "  2)  Clean package cache"
    echo "  3)  Check for orphaned packages"
    echo "  4)  Check system logs for errors"
    echo "  5)  Check disk health (SMART)"
    echo "  6)  Check disk usage (ncdu)"
    echo "  7)  View running services"
    echo "  8)  View resource usage (htop)"
    echo "  9)  Configure firewall (nftables)"
    echo " 10)  Set up automatic updates (systemd timer)"
    echo " 11)  Manage Docker (status / prune)"
    echo " 12)  Check SSL cert expiry"
    echo " 13)  Database maintenance (mariadb/pgsql status)"
    echo " 14)  Network diagnostics"
    echo " 15)  View installed server packages"
    echo ""
    echo "  s)  Strip GUI (remove desktop → TTY)"
    echo "  g)  Install GUI (add desktop back)"
    echo ""
    echo "  q)  Quit"
    echo ""
    read -r -p "Choice: " choice
}

while true; do
    show_menu
    case "${choice}" in
        1)
            info "Updating system..."
            pacman -Syu --noconfirm
            log "System updated."
            ;;
        2)
            info "Cleaning package cache..."
            paccache -r -k 2 -u
            log "Cache cleaned."
            ;;
        3)
            orphans=$(pacman -Qdtq 2>/dev/null || true)
            if [[ -z "${orphans}" ]]; then
                log "No orphaned packages."
            else
                warn "Orphaned packages found:"
                echo "${orphans}"
                read -r -p "Remove them? [y/N]: " yn
                if [[ "${yn}" == "y" ]]; then
                    pacman -Rns --noconfirm ${orphans} 2>/dev/null || true
                    log "Orphans removed."
                fi
            fi
            ;;
        4)
            info "Recent errors in journal:"
            journalctl -p 3 -b --no-hostname --no-pager -n 30 || true
            ;;
        5)
            info "Disk health (SMART)..."
            for disk in /dev/sd? /dev/nvme?n1; do
                [[ -b "${disk}" ]] || continue
                echo "  ${disk}:"
                smartctl -H "${disk}" 2>/dev/null | grep "SMART overall-health" || \
                    smartctl -H "${disk}" 2>/dev/null | grep "PASSED" || \
                    echo "    (SMART not available)"
            done
            ;;
        6)
            ncdu /
            ;;
        7)
            info "Enabled services:"
            systemctl list-units --type=service --state=running --no-pager --no-legend | \
                awk '{print "  " $1}' | head -30
            ;;
        8)
            htop
            ;;
        9)
            info "Current nftables rules:"
            nft list ruleset 2>/dev/null || echo "  (no nftables rules loaded)"
            echo ""
            read -r -p "Open firewall wizard? [y/N]: " yn
            if [[ "${yn}" == "y" ]]; then
                echo "  Quick rules:"
                echo "    1) Allow SSH only (default deny)"
                echo "    2) Allow SSH + HTTP + HTTPS"
                echo "    3) Allow all (wide open)"
                read -r -p "  Choice: " fw
                case "${fw}" in
                    1)
                        nft flush ruleset
                        nft add table inet filter
                        nft add chain inet filter input '{ type filter hook input priority 0; policy drop; }'
                        nft add chain inet filter forward '{ type filter hook forward priority 0; policy drop; }'
                        nft add chain inet filter output '{ type filter hook output priority 0; policy accept; }'
                        nft add rule inet filter input ct state related,established accept
                        nft add rule inet filter input iif lo accept
                        nft add rule inet filter input tcp dport 22 accept
                        nft add rule inet filter input icmp type echo-request accept
                        log "SSH-only firewall applied."
                        ;;
                    2)
                        nft flush ruleset
                        nft add table inet filter
                        nft add chain inet filter input '{ type filter hook input priority 0; policy drop; }'
                        nft add chain inet filter forward '{ type filter hook forward priority 0; policy drop; }'
                        nft add chain inet filter output '{ type filter hook output priority 0; policy accept; }'
                        nft add rule inet filter input ct state related,established accept
                        nft add rule inet filter input iif lo accept
                        nft add rule inet filter input tcp dport '{22,80,443}' accept
                        nft add rule inet filter input icmp type echo-request accept
                        log "SSH+HTTP+HTTPS firewall applied."
                        ;;
                    3)
                        nft flush ruleset
                        log "All firewall rules cleared."
                        ;;
                esac
                # Save rules
                mkdir -p /etc/nftables
                nft list ruleset > /etc/nftables/acreetionos-server.conf
                systemctl enable nftables.service 2>/dev/null || true
                log "Firewall rules saved."
            fi
            ;;
        10)
            info "Setting up automatic updates..."
            cat > /etc/systemd/system/acreetionos-auto-update.service << 'EOF'
[Unit]
Description=AcreetionOS Server automatic update

[Service]
Type=oneshot
ExecStart=/usr/bin/pacman -Syu --noconfirm
ExecStartPost=/usr/bin/paccache -r -k 2 -u
Nice=19
IOSchedulingClass=idle
EOF
            cat > /etc/systemd/system/acreetionos-auto-update.timer << 'EOF'
[Unit]
Description=Weekly automatic updates for AcreetionOS Server

[Timer]
OnCalendar=weekly
Persistent=true
RandomizedDelaySec=6h

[Install]
WantedBy=timers.target
EOF
            systemctl daemon-reload
            systemctl enable --now acreetionos-auto-update.timer 2>/dev/null || true
            log "Automatic updates enabled (weekly)."
            ;;
        11)
            info "Docker status:"
            systemctl status docker --no-pager --no-legend 2>/dev/null | head -3 || echo "  (docker not running)"
            echo ""
            read -r -p "Prune unused Docker data? [y/N]: " yn
            if [[ "${yn}" == "y" ]]; then
                docker system prune -af 2>/dev/null || true
                log "Docker pruned."
            fi
            ;;
        12)
            info "Checking SSL certificate expiry..."
            for cert in /etc/letsencrypt/live/*/fullchain.pem 2>/dev/null; do
                if [[ -f "${cert}" ]]; then
                    domain=$(basename "$(dirname "${cert}")")
                    expires=$(openssl x509 -enddate -noout -in "${cert}" 2>/dev/null | cut -d= -f2)
                    echo "  ${domain}: expires ${expires}"
                fi
            done
            if ! ls /etc/letsencrypt/live/*/fullchain.pem &>/dev/null; then
                echo "  (no Let's Encrypt certs found)"
            fi
            ;;
        13)
            info "Database services:"
            for svc in mariadb postgresql redis; do
                if systemctl is-enabled "${svc}" &>/dev/null; then
                    status=$(systemctl is-active "${svc}" 2>/dev/null)
                    echo "  ${svc}: ${status}"
                fi
            done
            ;;
        14)
            info "Network diagnostics..."
            echo "  IP:      $(ip -4 addr show scope global | grep inet | awk '{print $2}' | paste -sd,)"
            echo "  Gateway: $(ip route | grep default | awk '{print $3}' | head -1)"
            echo "  DNS:     $(resolvectl status 2>/dev/null | grep 'DNS Servers' | head -1 || echo '  (check /etc/resolv.conf)')"
            echo "  Uptime:  $(uptime -p)"
            echo ""
            read -r -p "Run ping test (8.8.8.8)? [y/N]: " yn
            if [[ "${yn}" == "y" ]]; then
                ping -c 4 8.8.8.8 2>&1 | tail -3
            fi
            read -r -p "Run traceroute (8.8.8.8)? [y/N]: " yn
            if [[ "${yn}" == "y" ]]; then
                traceroute -n -q 2 8.8.8.8 2>&1 | head -10
            fi
            ;;
        15)
            info "Installed server packages:"
            for pkg in nginx-mainline apache mariadb postgresql redis docker prometheus grafana netdata docker-compose bind dnsmasq wireguard-tools cloud-init libvirt; do
                if pacman -Q "${pkg}" &>/dev/null; then
                    ver=$(pacman -Q "${pkg}" | awk '{print $2}')
                    echo "  ✓ ${pkg} (${ver})"
                else
                    echo "  · ${pkg} (not installed)"
                fi
            done
            ;;
        s|S)
            /usr/local/bin/acreetionos-strip-gui tty
            ;;
        g|G)
            /usr/local/bin/acreetionos-install-gui
            ;;
        q|Q)
            echo ""
            log "Goodbye!"
            exit 0
            ;;
        *)
            warn "Invalid choice."
            ;;
    esac
    echo ""
    read -r -p "Press Enter to continue..."
done
