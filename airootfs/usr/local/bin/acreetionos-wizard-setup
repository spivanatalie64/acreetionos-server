#!/usr/bin/env bash
# AcreetionOS Server — System Setup Wizard
# First-time setup: hostname, locale, timezone, keyboard, users.
set -euo pipefail
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'
[[ $EUID -ne 0 ]] && exec sudo "$0" "$@"

while true; do
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}           ${BOLD}System Configuration${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  Current:"
    echo "  Hostname: $(hostname)"
    echo "  Timezone: $(timedatectl show --property=Timezone --value 2>/dev/null || cat /etc/timezone 2>/dev/null || echo 'UTC')"
    echo "  Locale:   $(localectl status 2>/dev/null | head -3 | tr '\n' ' ')"
    echo ""
    echo "  1)  Set hostname"
    echo "  2)  Set timezone (interactive list)"
    echo "  3)  Set locale"
    echo "  4)  Set keyboard layout"
    echo "  5)  Add a new user"
    echo "  6)  Change a user's password"
    echo "  7)  Delete a user"
    echo "  8)  View system info"
    echo "  9)  Run first-time setup wizard (all of the above)"
    echo ""
    echo "  b)  Back"
    echo ""
    read -r -p "  Choice: " sc
    case "$sc" in
        1)
            read -r -p "  New hostname: " nhost
            hostnamectl set-hostname "$nhost"
            echo "$nhost" > /etc/hostname
            sed -i "s/127.0.1.1.*/127.0.1.1   $nhost.localdomain $nhost/" /etc/hosts 2>/dev/null || true
            echo -e "${GREEN}[✓]${NC} Hostname set to $nhost" ;;
        2)
            echo "  Available timezones (scroll with Enter, q to quit):"
            timedatectl list-timezones 2>/dev/null | less || true
            read -r -p "  Enter timezone (e.g., America/New_York): " tz
            timedatectl set-timezone "$tz" 2>/dev/null && echo -e "${GREEN}[✓]${NC} Timezone set to $tz" || echo "  Invalid timezone." ;;
        3)
            echo "  Common locales:"
            echo "  1) en_US.UTF-8"
            echo "  2) en_GB.UTF-8"
            echo "  3) Other"
            read -r -p "  Choice: " lc
            case "$lc" in
                1) locale="en_US.UTF-8" ;;
                2) locale="en_GB.UTF-8" ;;
                3) read -r -p "  Locale (e.g., de_DE.UTF-8): " locale ;;
            esac
            if [[ -n "${locale:-}" ]]; then
                sed -i "s/^#${locale}/${locale}/" /etc/locale.gen 2>/dev/null || echo "${locale} UTF-8" >> /etc/locale.gen
                locale-gen 2>/dev/null || true
                localectl set-locale "LANG=${locale}" 2>/dev/null || true
                echo -e "${GREEN}[✓]${NC} Locale set to $locale"
            fi ;;
        4)
            echo "  Common layouts:"
            echo "  1) us (qwerty)"
            echo "  2) uk (qwerty)"
            echo "  3) de (qwertz)"
            echo "  4) fr (azerty)"
            echo "  5) Other"
            read -r -p "  Choice: " kc
            case "$kc" in 1) kb="us" ;; 2) kb="gb" ;; 3) kb="de" ;; 4) kb="fr" ;; 5) read -r -p "  Layout code: " kb ;; esac
            if [[ -n "${kb:-}" ]]; then
                localectl set-keymap "$kb" 2>/dev/null || true
                echo -e "${GREEN}[✓]${NC} Keyboard layout set to $kb"
            fi ;;
        5)
            read -r -p "  Username: " uname
            id "$uname" &>/dev/null && { echo "  User exists."; continue; }
            read -r -s -p "  Password: " upass; echo ""
            useradd -m -G wheel -s /bin/bash "$uname" 2>/dev/null || true
            echo "$uname:$upass" | chpasswd
            echo -e "${GREEN}[✓]${NC} User '$uname' created (in wheel group)" ;;
        6)
            read -r -p "  Username: " cuser
            id "$cuser" &>/dev/null || { echo "  User not found."; continue; }
            read -r -s -p "  New password: " cpass; echo ""
            echo "$cuser:$cpass" | chpasswd
            echo -e "${GREEN}[✓]${NC} Password changed for $cuser" ;;
        7)
            read -r -p "  Username to delete: " duser
            [[ "$duser" =~ ^(root|admin)$ ]] && { echo "  Cannot delete system users."; continue; }
            confirm "Delete user '$duser' and their home directory?" || continue
            userdel -r "$duser" 2>/dev/null || true
            echo -e "${YELLOW}[!]${NC} User '$duser' deleted." ;;
        8)
            echo ""; neofetch 2>/dev/null || fastfetch 2>/dev/null || uname -a ;;
        9)
            echo ""; echo "  ${BOLD}Welcome to AcreetionOS Server!${NC}"
            echo "  Let's get your system set up."
            echo ""
            read -r -p "  Hostname [acreetion-server]: " fhost; fhost="${fhost:-acreetion-server}"
            hostnamectl set-hostname "$fhost"
            echo "$fhost" > /etc/hostname
            echo ""
            read -r -p "  Timezone (e.g., America/New_York) [UTC]: " ftz; ftz="${ftz:-UTC}"
            timedatectl set-timezone "$ftz" 2>/dev/null || true
            echo ""
            read -r -p "  SSH key for admin user (optional, press Enter to skip): " fpkey
            if [[ -n "$fpkey" ]]; then
                mkdir -p /home/admin/.ssh
                echo "$fpkey" >> /home/admin/.ssh/authorized_keys
                chmod 700 /home/admin/.ssh; chmod 600 /home/admin/.ssh/authorized_keys
                chown -R admin:admin /home/admin/.ssh
            fi
            echo ""
            echo -e "${GREEN}[✓]${NC} System configured."
            echo "  Hostname: $fhost"
            echo "  Timezone: $ftz"
            echo "  SSH keys: $([ -f /home/admin/.ssh/authorized_keys ] && echo 'installed' || echo 'none')"
            echo ""
            if confirm "Regenerate GRUB and reboot now?" "y"; then
                grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null || true
                reboot
            fi ;;
        b|B) return ;;
    esac
    echo ""; read -r -p "Press Enter..."
done
