#!/usr/bin/env bash
# AcreetionOS Server — Docker Stack Deployer
# Deploy common server stacks with docker-compose.
set -euo pipefail
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'
STACK_DIR="/opt/stacks"
mkdir -p "$STACK_DIR"

deploy_stack() {
    local name="$1" dir="$STACK_DIR/$name"
    mkdir -p "$dir"
    cd "$dir"
    echo "$2" > docker-compose.yml
    echo "$3" > .env 2>/dev/null || true
    echo -e "  ${GREEN}Stack '$name' created in $dir${NC}"
    echo -n "  Start it now? [Y/n]: "
    read -r yn
    if [[ -z "$yn" || "$yn" =~ ^[Yy] ]]; then
        docker-compose up -d 2>/dev/null && echo -e "  ${GREEN}[✓]${NC} Stack started" || echo -e "  ${YELLOW}Start manually: cd $dir && docker-compose up -d${NC}"
    fi
}

while true; do
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}           ${BOLD}Docker Stack Deployer${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  1)  LEMP Stack — nginx + PHP + MariaDB"
    echo "  2)  LEMP + phpMyAdmin"
    echo "  3)  Prometheus + Grafana + Node Exporter"
    echo "  4)  PostgreSQL + pgAdmin"
    echo "  5)  WordPress"
    echo "  6)  Nextcloud"
    echo "  7)  Minecraft Server"
    echo "  8)  Portainer (container management UI)"
    echo "  9)  Custom — write your own docker-compose.yml"
    echo " 10)  List all deployed stacks"
    echo " 11)  Stop/remove a stack"
    echo ""
    echo "  b)  Back"
    echo ""
    read -r -p "  Choice: " sc
    case "$sc" in
        1)
            DOMAIN="${DOMAIN:-localhost}"
            deploy_stack "lemp" \
"version: '3.8'
services:
  nginx:
    image: nginx:alpine
    ports:
      - '80:80'
      - '443:443'
    volumes:
      - ./html:/usr/share/nginx/html
      - ./nginx.conf:/etc/nginx/conf.d/default.conf:ro
  php:
    image: php:8-fpm
    volumes:
      - ./html:/usr/share/nginx/html
  mariadb:
    image: mariadb:lts
    environment:
      MYSQL_ROOT_PASSWORD: \${DB_ROOT_PASSWORD}
    volumes:
      - db_data:/var/lib/mysql
volumes:
  db_data:" \
"DB_ROOT_PASSWORD=$(openssl rand -base64 24)"
            ;;
        2)
            deploy_stack "lemp-pma" \
"version: '3.8'
services:
  nginx:
    image: nginx:alpine
    ports: ['80:80','443:443']
    volumes: [./html:/usr/share/nginx/html]
  php:
    image: php:8-fpm
    volumes: [./html:/usr/share/nginx/html]
  mariadb:
    image: mariadb:lts
    environment: [MYSQL_ROOT_PASSWORD=\${DB_ROOT_PASSWORD}]
    volumes: [db_data:/var/lib/mysql]
  phpmyadmin:
    image: phpmyadmin:latest
    ports: ['8080:80']
    environment: [PMA_HOST=mariadb, PMA_ARBITRARY=1]
volumes:
  db_data:" \
"DB_ROOT_PASSWORD=$(openssl rand -base64 24)" ;;
        3)
            deploy_stack "monitoring" \
"version: '3.8'
services:
  prometheus:
    image: prom/prometheus
    ports: ['9090:9090']
    volumes: [./prometheus.yml:/etc/prometheus/prometheus.yml:ro,prom_data:/prometheus]
  grafana:
    image: grafana/grafana
    ports: ['3000:3000']
    environment: [GF_SECURITY_ADMIN_PASSWORD=\${GRAFANA_PASSWORD}]
    volumes: [grafana_data:/var/lib/grafana]
  node_exporter:
    image: prom/node-exporter
    ports: ['9100:9100']
volumes:
  prom_data: ; grafana_data:" \
"GRAFANA_PASSWORD=$(openssl rand -base64 24)" ;;
        4)
            deploy_stack "postgres" \
"version: '3.8'
services:
  postgres:
    image: postgres:16
    ports: ['5432:5432']
    environment: [POSTGRES_PASSWORD=\${PG_PASSWORD}]
    volumes: [pg_data:/var/lib/postgresql/data]
  pgadmin:
    image: dpage/pgadmin4
    ports: ['8080:80']
    environment: [PGADMIN_DEFAULT_EMAIL=admin@\${DOMAIN}, PGADMIN_DEFAULT_PASSWORD=\${PG_PASSWORD}]
volumes:
  pg_data:" \
"PG_PASSWORD=$(openssl rand -base64 24)
DOMAIN=localhost" ;;
        5)
            deploy_stack "wordpress" \
"version: '3.8'
services:
  wordpress:
    image: wordpress
    ports: ['80:80']
    environment:
      WORDPRESS_DB_HOST: mariadb
      WORDPRESS_DB_USER: wpuser
      WORDPRESS_DB_PASSWORD: \${WP_PASSWORD}
      WORDPRESS_DB_NAME: wordpress
    volumes: [wp_data:/var/www/html]
  mariadb:
    image: mariadb:lts
    environment: [MYSQL_ROOT_PASSWORD=\${DB_ROOT_PASSWORD}, MYSQL_DATABASE=wordpress, MYSQL_USER=wpuser, MYSQL_PASSWORD=\${WP_PASSWORD}]
    volumes: [db_data:/var/lib/mysql]
volumes:
  wp_data: ; db_data:" \
"WP_PASSWORD=$(openssl rand -base64 24)
DB_ROOT_PASSWORD=$(openssl rand -base64 24)" ;;
        6)
            deploy_stack "nextcloud" \
"version: '3.8'
services:
  nextcloud:
    image: nextcloud
    ports: ['80:80']
    volumes: [nc_data:/var/www/html]
  mariadb:
    image: mariadb:lts
    environment: [MYSQL_ROOT_PASSWORD=\${DB_ROOT_PASSWORD}, MYSQL_DATABASE=nextcloud, MYSQL_USER=ncuser, MYSQL_PASSWORD=\${NC_PASSWORD}]
    volumes: [db_data:/var/lib/mysql]
volumes:
  nc_data: ; db_data:" \
"NC_PASSWORD=$(openssl rand -base64 24)
DB_ROOT_PASSWORD=$(openssl rand -base64 24)" ;;
        7)
            deploy_stack "minecraft" \
"version: '3.8'
services:
  mc:
    image: itzg/minecraft-server
    ports: ['25565:25565']
    environment:
      EULA: 'TRUE'
      DIFFICULTY: normal
      OPS: \${MC_OPS}
    volumes: [mc_data:/data]
volumes:
  mc_data:" \
"MC_OPS=admin" ;;
        8)
            deploy_stack "portainer" \
"version: '3.8'
services:
  portainer:
    image: portainer/portainer-ce
    ports: ['9443:9443']
    volumes: [/var/run/docker.sock:/var/run/docker.sock,portainer_data:/data]
volumes:
  portainer_data:" "" ;;
        9)
            echo ""; read -r -p "  Stack name: " sname
            [[ -z "$sname" ]] && continue
            mkdir -p "$STACK_DIR/$sname"
            echo "  Paste your docker-compose.yml content, then press Ctrl+D:"
            cat > "$STACK_DIR/$sname/docker-compose.yml"
            echo -e "${GREEN}[✓]${NC} Stack saved to $STACK_DIR/$sname/docker-compose.yml" ;;
        10)
            echo ""; echo "  ${BOLD}Deployed stacks:${NC}"
            for d in "$STACK_DIR"/*/; do
                name=$(basename "$d")
                if [[ -f "$d/docker-compose.yml" ]]; then
                    running=$(cd "$d" && docker-compose ps --services --filter "status=running" 2>/dev/null | tr '\n' ',' || echo "not running")
                    echo "  $name — $running"
                fi
            done ;;
        11)
            read -r -p "  Stack name to remove: " rname
            [[ -z "$rname" ]] && continue
            if [[ -d "$STACK_DIR/$rname" ]]; then
                cd "$STACK_DIR/$rname"
                docker-compose down -v 2>/dev/null || true
                rm -rf "$STACK_DIR/$rname"
                echo -e "${YELLOW}[!]${NC} Stack '$rname' removed (data volumes preserved if external)."
            fi ;;
        b|B) return ;;
    esac
    echo ""; read -r -p "Press Enter..."
done
