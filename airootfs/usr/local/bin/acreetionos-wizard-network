#!/usr/bin/env bash
# AcreetionOS Server — Network Configuration Wizard
# Static IP, bridges, VLANs, bonds via NetworkManager.
set -euo pipefail
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; CYAN='\033[0;36m'; NC='\033[0m'; BOLD='\033[1m'
[[ $EUID -ne 0 ]] && exec sudo "$0" "$@"

while true; do
    clear
    echo -e "${CYAN}╔══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}           ${BOLD}Network Configuration${NC}"
    echo -e "${CYAN}╚══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo "  ${BOLD}Current interfaces:${NC}"
    nmcli -t -f DEVICE,TYPE,STATE device status 2>/dev/null | head -10 | sed 's/^/  /' | tr ':' ' '
    echo ""
    echo "  1)  Set static IP address"
    echo "  2)  Set DHCP (reset to automatic)"
    echo "  3)  Create a network bridge (for VMs)"
    echo "  4)  Create a VLAN interface"
    echo "  5)  Set DNS servers"
    echo "  6)  Set hostname"
    echo "  7)  View connection details"
    echo "  8)  Test connectivity (ping)"
    echo ""
    echo "  b)  Back"
    echo ""
    read -r -p "  Choice: " nc
    case "$nc" in
        1)
            echo ""; nmcli device status 2>/dev/null | head -10
            read -r -p "  Interface name (e.g., eth0, ens18): " iface
            [[ -z "$iface" ]] && continue
            read -r -p "  IP address (e.g., 192.168.1.100/24): " ipaddr
            [[ -z "$ipaddr" ]] && continue
            read -r -p "  Gateway (e.g., 192.168.1.1): " gateway
            read -r -p "  DNS (e.g., 1.1.1.1,8.8.8.8): " dns
            nmcli con mod "$iface" ipv4.addresses "$ipaddr" 2>/dev/null || \
            nmcli con mod "$(nmcli -t -f NAME con show --active 2>/dev/null | head -1)" ipv4.addresses "$ipaddr" 2>/dev/null || true
            [[ -n "$gateway" ]] && nmcli con mod "$iface" ipv4.gateway "$gateway" 2>/dev/null || true
            [[ -n "$dns" ]] && nmcli con mod "$iface" ipv4.dns "$dns" 2>/dev/null || true
            nmcli con mod "$iface" ipv4.method manual 2>/dev/null || true
            nmcli con down "$iface" 2>/dev/null || true
            nmcli con up "$iface" 2>/dev/null || true
            echo -e "${GREEN}[✓]${NC} Static IP configured: $ipaddr" ;;
        2)
            read -r -p "  Interface name: " diface
            nmcli con mod "$diface" ipv4.method auto 2>/dev/null || true
            nmcli con down "$diface" 2>/dev/null || true
            nmcli con up "$diface" 2>/dev/null || true
            echo -e "${GREEN}[✓]${NC} DHCP enabled on $diface" ;;
        3)
            read -r -p "  Bridge name (e.g., br0): " brname
            [[ -z "$brname" ]] && continue
            read -r -p "  Attach interface (or Enter to skip): " briface
            nmcli con add type bridge con-name "$brname" ifname "$brname" 2>/dev/null || true
            [[ -n "$briface" ]] && nmcli con add type bridge-slave con-name "${brname}-${briface}" ifname "$briface" master "$brname" 2>/dev/null || true
            echo -e "${GREEN}[✓]${NC} Bridge '$brname' created"
            echo "  Configure its IP with option 1, selecting $brname as interface." ;;
        4)
            read -r -p "  Parent interface (e.g., eth0): " vparent
            read -r -p "  VLAN ID (e.g., 100): " vid
            [[ -z "$vparent" || -z "$vid" ]] && continue
            nmcli con add type vlan con-name "${vparent}.${vid}" ifname "${vparent}.${vid}" dev "$vparent" id "$vid" 2>/dev/null || true
            echo -e "${GREEN}[✓]${NC} VLAN ${vid} on ${vparent} created. Configure IP with option 1." ;;
        5)
            read -r -p "  Interface: " diface
            read -r -p "  DNS servers (comma-separated, e.g., 1.1.1.1,8.8.8.8): " dns_servers
            nmcli con mod "$diface" ipv4.dns "$dns_servers" 2>/dev/null || true
            nmcli con down "$diface" 2>/dev/null || true
            nmcli con up "$diface" 2>/dev/null || true
            echo -e "${GREEN}[✓]${NC} DNS updated" ;;
        6)
            read -r -p "  New hostname: " nhost
            hostnamectl set-hostname "$nhost" 2>/dev/null || true
            echo "$nhost" > /etc/hostname
            echo -e "${GREEN}[✓]${NC} Hostname set to $nhost" ;;
        7)
            echo ""; ip addr show 2>/dev/null | grep -E "inet |link/" | sed 's/^/  /'
            echo ""; echo "  DNS:"; resolvectl status 2>/dev/null | head -10 || cat /etc/resolv.conf 2>/dev/null | sed 's/^/  /' ;;
        8)
            read -r -p "  Host to ping: " phost
            ping -c 4 "${phost:-8.8.8.8}" 2>/dev/null | tail -3 || echo "  Ping failed." ;;
        b|B) return ;;
    esac
    echo ""; read -r -p "Press Enter..."
done
